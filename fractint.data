   }

JMask = {; Ron Barnett [70153,1233]
   ; try p1 = (1,0), p2 = (0,0.835), fn1 = sin, fn2 = sqr
   z = fn1(pixel):
   z = P1*fn2(z)^2 + P2, |z| <= 4
   }

joc {; from EXPLOD.FRM
