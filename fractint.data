adh6894 { ; Anthony Hanmer 2001, a.hanmer@gmail.com
  Angle 8 ; DC from 6829:
  Axiom x ; My only irregular-interior DC so far
  ; More work to be found at:
  ; http://spanky.triumf.ca/pub/fractals/LSYSTEMS/
  ; in TDC.l
  x=f[@iq2-x]|[+!+!@.5x]f[@iq2+x]
  }

